PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=freelancer_scheduler
JWT_SECRET=replace_with_strong_secret

# Frontend callback URL for OAuth redirects
FRONTEND_URL=http://localhost:5173

# Comma-separated list. Keep localhost for dev + add deployed frontend URL(s).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

GROQ_API_KEY=your_groq_api_key
